# Copy to .env (gitignored). NEVER commit real values, numbers, or keys.

# --- AgentPhone (mandatory platform) ---
AGENTPHONE_API_KEY=YOUR_AGENTPHONE_API_KEY
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_WEBHOOK_SECRET=YOUR_AGENTPHONE_WEBHOOK_SECRET
# Public HTTPS URL AgentPhone will POST webhooks to (tunnel or Railway)
PUBLIC_URL=

# --- LLM for the webhook tool-call loop (Claude) ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# --- Browser Use (mandatory: web actions) ---
BROWSER_USE_API_KEY=YOUR_BROWSER_USE_API_KEY

# --- Optional sponsor hooks (bonus tracks only) ---
MOSS_API_KEY=

# --- W1: Super Memory (caller history recall) ---
ROBIN_MEMORY_ENABLED=
SUPERMEMORY_API_KEY=

# --- Demo inputs (PII — never commit the real .env) ---
# The number Robin calls you back on:
CALLBACK_NUMBER=+1555XXXXXXX

# --- W2: Agent Mail close-loop (bonus track) ---
# Set to "1" to enable; absent = no-op (default).
ROBIN_AGENTMAIL_ENABLED=
AGENTMAIL_API_KEY=
# Optional: presenter email for the caller confirmation email.
# Add "email": "you@example.com" to context_pack.json (gitignored).
# NEVER put a real email address in this file.
